}

type EditCombosPayload {
  success: Boolean
  code: String
  message: String
  combos: Combos
  clientMutationId: String
}

input EditCombosInput {
  id: UUID!
  clientMutationId: String
}

type DeleteCombosPayload {
  success: Boolean
  code: String
  message: String
  combos: Combos
  clientMutationId: String
}

input DeleteCombosInput {
  id: UUID!
  clientMutationId: String
}

